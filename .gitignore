# ──────────────────────────────
# Environment / secrets
# ──────────────────────────────
.env
.env.local
.env.*.local

# Always commit example files (safe templates, no real secrets)
!.env.example
!**/.env.example

# ──────────────────────────────
# Python / uv (backend)
# ──────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
*.db          # SQLite dev fallback

# ──────────────────────────────
# Node / Bun (frontend)
# ──────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# Bun
bun.lockb

# ──────────────────────────────
# Logs
# ──────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────
# Editor & OS
# ──────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.sw?

# ──────────────────────────────
# Docker
# ──────────────────────────────
# keep docker-compose.yml, ignore override files
docker-compose.override.yml
